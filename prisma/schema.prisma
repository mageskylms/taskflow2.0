generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

enum Priority {
  BAIXA
  MEDIA
  ALTA
}

enum Status {
  TODO          // A Fazer
  IN_PROGRESS   // Em Progresso
  DONE          // Concluído
}

model Category {
  id     Int    @id @default(autoincrement())
  nome   String
  cor    String?
  userId String // <--- NOVO: ID do usuário do Clerk
  tasks  Task[]
  
  // Garante que não existam duas categorias com mesmo nome PARA O MESMO USUÁRIO
  @@unique([nome, userId]) 
}

model Task {
  id          Int       @id @default(autoincrement())
  titulo      String
  descricao   String?
  dataLimite  DateTime?
  criadoEm    DateTime  @default(now())
  status      Status    @default(TODO)
  priority    Priority  @default(BAIXA)
  
  userId      String    // <--- NOVO: ID do usuário do Clerk

  categoryId  Int?
  category    Category? @relation(fields: [categoryId], references: [id])
  subtasks    Subtask[]
}

model Subtask {
  id        Int     @id @default(autoincrement())
  titulo    String
  concluida Boolean @default(false)
  taskId    Int
  task      Task    @relation(fields: [taskId], references: [id], onDelete: Cascade)
}

model Feedback {
  id        Int      @id @default(autoincrement())
  mensagem  String
  tipo      String
  userId    String?
  nome      String?  
  createdAt DateTime @default(now())
}